{
  "$schema": "https://schemas.wp.org/wp/6.5/theme.json",
  "version": 3,
  "customTemplates": [
    {
      "name": "bureau",
      "title": "Bureau",
      "postTypes": [
        "page"
      ]
    },
    {
      "name": "atelier",
      "title": "Atelier",
      "postTypes": [
        "page"
      ]
    }
  ],
  "templateParts": [
    {
      "name": "header",
      "title": "Header",
      "area": "header"
    },
    {
      "name": "footer",
      "title": "Footer",
      "area": "footer"
    }
  ],
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "1024px",
      "wideSize": "1280px"
    },
    "color": {
      "palette": [
        {
          "slug": "black",
          "name": "Black",
          "color": "#111111"
        },
        {
          "slug": "white",
          "name": "White",
          "color": "#ffffff"
        },
        {
          "slug": "soft-gray",
          "name": "Soft Gray",
          "color": "#f2f2f2"
        }
      ]
    },
    "typography": {
      "fluid": false
    }
  },
  "styles": {
    "spacing": {
      "blockGap": "1.5rem"
    }
  }
}
